generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  WISHLIST
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

model Application {
  id         String            @id @default(cuid())
  company    String
  role       String
  location   String?
  sourceUrl  String?
  notes      String?
  status     ApplicationStatus @default(WISHLIST)
  appliedAt  DateTime?
  deadlineAt DateTime?
  followUpAt DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}
