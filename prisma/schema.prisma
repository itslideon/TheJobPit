generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  passwordHash         String
  name                 String?
  headline             String?
  bio                  String?
  location             String?
  phone                String?
  linkedinUrl          String?
  githubUrl            String?
  twitterUrl           String?
  websiteUrl           String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  applications         Application[]
  companies            Company[]
  starStories          StarStory[]
  interviewQuestions   InterviewQuestion[]
  passwordResetTokens  PasswordResetToken[]
  gameProfile          UserGameProfile?
  gameBadges           UserGameBadge[]
  gameEvents           GamificationEvent[]
}

model UserGameProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gamificationEnabled Boolean  @default(true)
  xp                 Int      @default(0)
  level              Int      @default(1)
  streakDays         Int      @default(0)
  longestStreakDays  Int      @default(0)
  lastActivityDate   DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model UserGameBadge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String
  createdAt DateTime @default(now())

  @@unique([userId, key])
  @@index([userId, createdAt])
}

model GamificationEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  title     String
  detail    String?
  xpDelta   Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

enum ApplicationStatus {
  WISHLIST
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

model Application {
  id                  String                 @id @default(cuid())
  userId              String?
  user                User?                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  company             String
  role                String
  location            String?
  sourceUrl           String?
  notes               String?
  status              ApplicationStatus      @default(WISHLIST)
  appliedAt           DateTime?
  deadlineAt          DateTime?
  followUpAt          DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  documents           ApplicationDocument[]
  starStories         StarStory[]
  interviewQuestions  InterviewQuestion[]
  mockInterviewNotes  MockInterviewNote[]
}

enum DocumentType {
  RESUME
  COVER_LETTER
}

model ApplicationDocument {
  id                     String        @id @default(cuid())
  applicationId          String
  application            Application   @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type                   DocumentType
  title                  String
  content                String        @default("")
  attachmentUrl          String?
  attachmentOriginalName String?
  attachmentMime         String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
}

model StarStory {
  id                    String       @id @default(cuid())
  userId                String?
  user                  User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  applicationId         String?
  application           Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  title                 String
  situation             String
  task                  String
  action                String
  result                String
  isPublic              Boolean      @default(false)
  shareCompanyContext   Boolean      @default(false)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@index([isPublic, updatedAt])
}

model InterviewQuestion {
  id            String       @id @default(cuid())
  userId        String?
  user          User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  applicationId String?
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  question      String
  answer        String?
  category      String?
  isPublic      Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([isPublic, updatedAt])
}

model MockInterviewNote {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  occurredAt    DateTime?
  notes         String
  rating        Int?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Company {
  id        String           @id @default(cuid())
  userId    String?
  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  website   String?
  industry  String?
  salaryMin Int?
  salaryMax Int?
  currency  String?          @default("USD")
  notes     String?
  contacts  CompanyContact[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model CompanyContact {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name       String
  role       String?
  email      String?
  linkedin   String?
  isReferral Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
