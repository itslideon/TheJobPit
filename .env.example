DATABASE_URL="postgresql://postgres:postgres@localhost:5432/thejobpit?schema=public"

# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"
AUTH_URL="http://localhost:3000"

# Password reset emails (https://resend.com). In development, if unset, the reset URL is printed to the server console.
# RESEND_API_KEY="re_..."
# EMAIL_FROM="The Job Pit <onboarding@resend.dev>"

# Job matching source
# 1 = use live Singapore source (MyCareersFuture API) when reachable, fallback to local sample data
# 0 = always use local sample openings
# JOB_MATCH_USE_LIVE="1"
# Optional override:
# MCF_API_URL="https://api.mycareersfuture.gov.sg/v2/search"
# Optional additional SG feeds (your own proxy endpoints that return JSON job arrays):
# LINKEDIN_SG_FEED_URL="https://your-proxy.example.com/linkedin-sg-jobs"
# GLASSDOOR_SG_FEED_URL="https://your-proxy.example.com/glassdoor-sg-jobs"
